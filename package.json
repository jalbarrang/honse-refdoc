{
  "name": "honse-refdoc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "pnpm run content:build",
    "dev": "vinxi dev",
    "prebuild": "pnpm run content:build",
    "build": "vinxi build",
    "preview": "vinxi preview",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --deny-warnings .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "content:build": "tsx scripts/content/build-content.ts",
    "content:check": "tsx scripts/content/validate-content.ts",
    "check:lines": "node scripts/check-source-size.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "pnpm run content:check && pnpm run typecheck && pnpm run lint && pnpm run check:lines && pnpm run format:check && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@fontsource-variable/figtree": "5.3.0",
    "@fontsource-variable/newsreader": "5.3.0",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.16.2",
    "@solidjs/start": "1.3.2",
    "solid-js": "1.9.14",
    "vinxi": "0.5.11"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.3",
    "@types/node": "24.0.15",
    "marked": "18.0.6",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "tailwindcss": "4.3.3",
    "tsx": "4.20.3",
    "typescript": "7.0.2",
    "vite": "6.4.3",
    "vitest": "4.1.10"
  }
}
