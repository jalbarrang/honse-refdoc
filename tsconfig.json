{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["vinxi/types/client", "node", "vitest/globals"],
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": ["src", "scripts", "tests", "*.ts"]
}
